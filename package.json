{
  "name": "sprint9",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down --volumes",
    "docker:clean": "docker compose down --volumes --rmi all --remove-orphans",
    "mikro:create": "npx mikro-orm migration:create",
    "mikro:up": "npx mikro-orm migration:up",
    "mikro:seed": "ts-node src/seeds/seed.ts",
    "build": "tsc --clean",
    "start": "node dist/app.js",
    "dev": "nodemon --watch 'src/**/*.ts' --exec ts-node src/app.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:integration": "jest tests/integration --runInBand",
    "test:root": "jest tests/integration/root.test.ts --runInBand",
    "test:auth": "jest tests/integration/auth.test.ts --runInBand",
    "test:users": "jest tests/integration/users.test.ts --runInBand",
    "test:products": "jest tests/integration/products.test.ts --runInBand",
    "test:articles": "jest tests/integration/articles.test.ts --runInBand",
    "test:article-comments": "jest tests/integration/article-comments.test.ts --runInBand",
    "test:product-comments": "jest tests/integration/product-comments.test.ts --runInBand",
    "test:images": "jest tests/integration/images.test.ts --runInBand",
    "test:logs": "jest tests/integration/logs.test.ts --runInBand",
    "test:notifications": "jest tests/integration/notifications.test.ts --runInBand",
    "test:unit": "jest tests/unit --runInBand",
    "test:product": "jest tests/unit/product.test.ts --runInBand"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@mikro-orm/core": "^6.4.16",
    "@mikro-orm/postgresql": "^6.4.16",
    "bcrypt": "^6.0.0",
    "cookie": "^1.0.2",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "dotenv": "^17.0.0",
    "express": "^5.1.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@mikro-orm/cli": "^6.4.16",
    "@mikro-orm/migrations": "^6.4.16",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie": "^0.6.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.3",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/socket.io": "^3.0.1",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "jest": "^30.1.1",
    "multer": "^2.0.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
