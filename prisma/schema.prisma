generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  master
}

enum ProductStatus {
  active
  inactive
  sold_out
}

enum UserStatus {
  active
  inactive
  lock
}


enum CommonStatus {
  active
  inactive
}

model User {

  id                  String               @id @default(uuid())
  nickname            String
  email               String               @unique
  password            String
  status              UserStatus           @default(active)
  role                UserRole             @default(user)
  image               Image?               @relation(fields: [imageId], references: [id])
  imageId             String?
  isArchiveUser       Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?
  lastLoginAt         DateTime?
  lastLoginIp         String?
  loginAttempts       Int                  @default(0)
  products            Product[]
  articles            Article[]
  productComments     ProductComment[]
  articleComments     ArticleComment[]
  refreshToken        RefreshToken[]
  productLikes        ProductLike[]
  articleLikes        ArticleLike[]
  productCommentLikes ProductCommentLike[]
  articleCommentLikes ArticleCommentLike[]

}

model Product {
  id          String             @id @default(uuid())
  user        User               @relation(fields: [userId], references: [id])
  userId      String
  name        String
  description String
  price       Int                @default(1)
  stock       Int                @default(1)
  tags        ProductTag[]       @relation("ProductTags")
  status      ProductStatus      @default(active)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?
  images      ProductImageLink[]
  comments    ProductComment[]
  likes       ProductLike[]
}

model ProductComment {
  id        String               @id @default(uuid())
  content   String
  user      User                 @relation(fields: [userId], references: [id])
  userId    String
  product   Product              @relation(fields: [productId], references: [id])
  productId String
  status    CommonStatus         @default(active)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  deletedAt DateTime?
  likes     ProductCommentLike[]
}

model Article {
  id        String             @id @default(uuid())
  title     String
  content   String
  user      User               @relation(fields: [userId], references: [id])
  userId    String
  tags      ArticleTag[]       @relation("ArticleTags")
  status    CommonStatus       @default(active)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  deletedAt DateTime?
  images    ArticleImageLink[]
  comments  ArticleComment[]
  likes     ArticleLike[]
}

model ArticleComment {
  id        String               @id @default(uuid())
  content   String
  user      User                 @relation(fields: [userId], references: [id])
  userId    String
  article   Article              @relation(fields: [articleId], references: [id])
  articleId String
  status    CommonStatus         @default(active)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  deletedAt DateTime?
  likes     ArticleCommentLike[]

}

model ProductImageLink {
  id        String  @id @default(uuid())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  image     Image   @relation(fields: [imageId], references: [id], onDelete: Cascade)
  imageId   String
}

model ArticleImageLink {
  id        String  @id @default(uuid())
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId String
  image     Image   @relation(fields: [imageId], references: [id], onDelete: Cascade)
  imageId   String
}

model ProductTag {
  id        String       @id @default(uuid())
  name      String       @unique
  status    CommonStatus @default(active)
  products  Product[]    @relation("ProductTags")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?
}

model ArticleTag {
  id        String       @id @default(uuid())
  name      String       @unique
  status    CommonStatus @default(active)
  articles  Article[]    @relation("ArticleTags")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?
}

model Image {
  id            String             @id @default(uuid())
  name          String
  url           String
  ext           String
  createdAt     DateTime           @default(now())
  productImages ProductImageLink[]
  articleImages ArticleImageLink[]
  User          User[]
}

model ProductLike {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model ArticleLike {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId String
  createdAt DateTime @default(now())

  @@unique([userId, articleId])
}

model ProductCommentLike {
  id               String         @id @default(uuid())
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  productComment   ProductComment @relation(fields: [productCommentId], references: [id], onDelete: Cascade)
  productCommentId String
  createdAt        DateTime       @default(now())

  @@unique([userId, productCommentId])
}

model ArticleCommentLike {
  id               String         @id @default(uuid())
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  articleComment   ArticleComment @relation(fields: [articleCommentId], references: [id], onDelete: Cascade)
  articleCommentId String
  createdAt        DateTime       @default(now())

  @@unique([userId, articleCommentId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
}

// LOG
model Log {
  id         String   @id @default(uuid())
  ip         String
  url        String
  method     String
  statusCode String
  message    String
  createdAt  DateTime @default(now())
}
