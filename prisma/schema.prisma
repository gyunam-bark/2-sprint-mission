generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  master
}

enum ProductStatus {
  active
  inactive
  sold_out
}

enum CommonStatus {
  active
  inactive
}

model User {
  id              String           @id @default(uuid())
  name            String
  email           String           @unique
  password        String
  status          CommonStatus     @default(active)
  role            UserRole         @default(user)
  isAnonymous     Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  lastLoginAt     DateTime?
  lastLoginIp     String?
  products        Product[]
  articles        Article[]
  productComments ProductComment[]
  articleComments ArticleComment[]
}

model Product {
  id          String             @id @default(uuid())
  user        User               @relation(fields: [userId], references: [id])
  userId      String
  name        String
  description String
  price       Int
  stock       Int                @default(1)
  tags        ProductTag[]       @relation("ProductTags")
  status      ProductStatus      @default(active)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?
  images      ProductImageLink[]
  comments    ProductComment[]
}

model ProductComment {
  id        String       @id @default(uuid())
  content   String
  user      User         @relation(fields: [userId], references: [id])
  userId    String
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  status    CommonStatus @default(active)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?
}

model Article {
  id        String             @id @default(uuid())
  title     String
  content   String
  user      User               @relation(fields: [userId], references: [id])
  userId    String
  tags      ArticleTag[]       @relation("ArticleTags")
  status    CommonStatus       @default(active)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  deletedAt DateTime?
  images    ArticleImageLink[]
  comments  ArticleComment[]
}

model ArticleComment {
  id        String       @id @default(uuid())
  content   String
  user      User         @relation(fields: [userId], references: [id])
  userId    String
  article   Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId String
  status    CommonStatus @default(active)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?
}

model ProductImageLink {
  id        String  @id @default(uuid())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  image     Image   @relation(fields: [imageId], references: [id], onDelete: Cascade)
  imageId   String
}

model ArticleImageLink {
  id        String  @id @default(uuid())
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId String
  image     Image   @relation(fields: [imageId], references: [id], onDelete: Cascade)
  imageId   String
}

model ProductTag {
  id        String       @id @default(uuid())
  name      String       @unique
  status    CommonStatus @default(active)
  products  Product[]    @relation("ProductTags")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?
}

model ArticleTag {
  id        String       @id @default(uuid())
  name      String       @unique
  status    CommonStatus @default(active)
  articles  Article[]    @relation("ArticleTags")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?
}

model Image {
  id            String             @id @default(uuid())
  name          String
  url           String
  ext           String
  createdAt     DateTime           @default(now())
  productImages ProductImageLink[]
  articleImages ArticleImageLink[]
}
